{
  "lines": [
    {
      "character": "Narrator",
      "text": "翡翠德鲁伊圣地是自然之灵的最后庇护所。",
      "expression": "neutral"
    },
    {
      "character": "Narrator",
      "text": "古老的树木在这里仍然能行走，石头仍然会哭泣。",
      "expression": "neutral"
    },
    {
      "character": "Narrator",
      "text": "翡翠德鲁伊守护着自然法则——但他不会原谅文明的入侵。",
      "expression": "neutral"
    }
  ]
}