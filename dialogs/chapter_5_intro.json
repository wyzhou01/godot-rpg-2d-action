    {
      "character": "Narrator",
      "text": "烈焰之心是火山的最深处。",
      "expression": "neutral"
    },
    {
      "character": "Narrator",
      "text": "这里没有阴影，因为一切阴影都被吞噬。",
      "expression": "neutral"
    },
    {
      "character": "Narrator",
      "text": "焰心是火焰元素的领主——他只会一种语言：燃烧。",
      "expression": "neutral"
    }
