{
  "lines": [
    {
      "character": "Narrator",
      "text": "腐木森林曾是精灵的圣地，树木能说话，鸟儿会唱歌。",
      "expression": "neutral"
    },
    {
      "character": "Narrator",
      "text": "直到腐败从地底渗出。",
      "expression": "neutral"
    },
    {
      "character": "Narrator",
      "text": "腐烂领主曾经是森林的守护者——现在他只剩下饥饿。",
      "expression": "neutral"
    }
  ]
}